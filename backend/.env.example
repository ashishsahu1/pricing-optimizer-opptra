# Azure AI Foundry — OpenAI-compatible endpoint.
# Copy this file to `.env` and fill in your values. `.env` is git-ignored; never commit keys.
#
# If these are left blank the backend degrades gracefully to a deterministic
# template recommendation, so the whole pipeline still runs without credentials.

FOUNDRY_ENDPOINT=https://<your-resource>.services.ai.azure.com/openai/v1
FOUNDRY_API_KEY=<your-key>
FOUNDRY_MODEL=gpt-4.1
